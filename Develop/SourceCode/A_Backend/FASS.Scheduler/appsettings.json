{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug",
      "Microsoft.Hosting.Lifetime": "Debug",
      "Microsoft.EntityFrameworkCore": "Debug"
    }
  },
  "AllowedHosts": "*",

  "Serilog": {
    "Using": [ "Serilog.Sinks.Debug", "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Debug" },
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "shared": true,
          "path": "Logs/log.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": "104857600",
          "rollOnFileSizeLimit": true,
          "retainedFileTimeLimit": "90.00:00:00",
          "retainedFileCountLimit": "100",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {Message:lj} [{SourceContext}]{NewLine}{Exception}"
        }
      }
    ]
  },

  "App": {
    "ActivationCode": "592AF4AF3F7220EEF6F36BCD3A13E9B0ED5D4DC3F005F6D2246764DAF89F09AF9DEC5D4980D3C37F2E6AE2549C1419E9E7523855BAFB9EEE1C87A9678F2D78B00B86FDA6F90E982954B2D6822FF9CF2BA886CECE89ECADC8A313ACAB5488D5395C6CDB84EF3D3D493DAE28612DAFF36FA1F96F6848FEA1D5ACE021A54FF67FBB12E54730C498F905179422FF56F7FA95"
  },
  "Frame": {
    "Database": {
      "IsEnable": true,
      //Provider 支持 SqlServer/MySql/PostgreSql/Sqlite
      "Provider": "PostgreSql",
      //PostgreSql 示例
      "ConnectionString": "Server=127.0.0.1;Port=5432;Database=frcs-new;Username=postgres;Password=123456;Pooling=true",
      "EnableSplitQuery": true,
      "EnableChecks": false,
      "EnableSensitiveDataLogging": false,
      "EnableDetailedErrors": false,
      "EnableDataAudit": false
    },
    "Cache": {
      "IsEnable": true,
      //Provider 支持 Memory/Redis
      "Provider": "Redis",
      //Redis 示例
      "ConnectionString": "127.0.0.1:6379,ssl=false,defaultDatabase=0,connectTimeout=5000,abortConnect=false"
    },
    "EventBus": {
      "IsEnable": true,
      //StorageProvider 支持 Memory/SqlServer/MySql/PostgreSql/Sqlite
      "StorageProvider": "PostgreSql",
      //PostgreSql 示例
      "StorageConnectionString": "Server=127.0.0.1;Port=5432;Database=frcs-new;Username=postgres;Password=123456;Pooling=true",
      //TransportProvider 支持 Memory/RabbitMQ/Kafka/Redis
      "TransportProvider": "Redis",
      //Redis 示例
      "TransportConnectionString": "127.0.0.1:6379,ssl=false,defaultDatabase=0,connectTimeout=5000,abortConnect=false"
    },
    "CronTask": {
      "IsEnable": true,
      //Provider 支持 Memory/SqlServer/MySql/PostgreSql/Sqlite
      "Provider": "Memory"
      //PostgreSql 示例
      //"ConnectionString": "Server=127.0.0.1;Port=5432;Database=facs;Username=postgres;Password=123456;Pooling=true"
    }
  },
  "Server": {
    "Urls": [ "http://localhost:20101", "http://*:20101" ],
    "TcpServerLocalIP": "0.0.0.0:20102",
    "UdpServerLocalIP": "0.0.0.0:20103"
  },
  "Scheduler": {
    "LockCount": 2,
    "ArchiveDueTime": 60000,
    "UpdateDueTime": 3000,
    "TrafficDueTime": 2000,
    "FlowDueTime": 1000,
    "CarDueTime": 200,
    "DataDueTime": 100,
    "StateDueTime": 100
  },
  "Auth": {
    "SigningKey": "12345678123456781234567812345678",
    "Issuer": "12345678",
    "Audience": "12345678",
    "ExpireSeconds": 86400
  },
  "Plugin": {
    "EnablePlugin": false,
    "PluginDirectory": "Plugins"
  },
  "Event": {
    "EnableCar": false,
    "CarConfig": "Configs/CarConfig/Test.json",
    "EnableExtend": true
  },
  "Extend": {
    "EnableComClient": false,
    "ComClientPortName": "COM1",
    "EnableTcpClient": false,
    "TcpClientRemoteIP": "127.0.0.1:10001",
    "EnableTcpServer": false,
    "TcpServerLocalIP": "127.0.0.1:20001",
    "EnableUdpServer": false,
    "UdpServerRemoteIP": "127.0.0.1:10002",
    "UdpServerLocalIP": "127.0.0.1:20002",
    "EnableHttpClient": false,
    "HttpClientBaseAddress": "http://localhost:10101/",
    "EnableHttpServer": false,
    "HttpServerPrefixes": [ "http://localhost:20102/" ],
    "EnableMdcsTaskSync": false, //mdcs任务同步开关
    "MdcsTaskSyncDueTime": 10000, //任务同步频率
    "EnableStandardAlarmServer": false, //fass标准协议报警开关
    "StandardAlarmDueTime": 1000, //fass标准协议报警计算频率
    "EnableEmptyBucketFilling": false, //空桶补位任务开关
    "FillingDueTime": 10000 //空桶补位任务频率
  },
  "Mdcs": {
    "SimpleUrl": "http://127.0.0.1:8222"
  }
}